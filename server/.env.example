PORT=4000
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/inventory_hub?schema=public"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="http://localhost:5173"
COOKIE_NAME="inventory_hub_session"
BCRYPT_ROUNDS=12
NODE_ENV="development"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-app-password"
SMTP_FROM="Inventory Hub <your-email@gmail.com>"
